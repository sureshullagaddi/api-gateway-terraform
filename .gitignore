# ── Terraform ────────────────────────────────────────────────────────────────
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfplan
tfplan

# Terraform variable files with real values (use *.tfvars.example for templates)
terraform.tfvars
*.auto.tfvars

# ── Lambda build artefacts ────────────────────────────────────────────────────
# lambda.zip is AUTO-GENERATED by Terraform's archive_file data source
# from lambda/src/ on every terraform plan/apply.
# Never commit it — source code in lambda/src/ is all that's needed.
lambda/lambda.zip
lambda/**/*.zip

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.iml
*.iws
*.ipr

# ── Secrets & credentials ─────────────────────────────────────────────────────
*.pem
*.key
.env
.env.*
